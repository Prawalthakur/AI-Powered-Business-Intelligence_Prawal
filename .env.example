# ============================================
# IMPORTANT: Copy this file to .env and add your API keys
# ============================================
# DO NOT commit .env to git - it's in .gitignore
# For detailed instructions, see: env/README.md
# ============================================

# REQUIRED: OpenAI API Key
# Get yours from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-api-key-here...

# OPTIONAL: Anthropic Claude API Key
# Get yours from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-...your-api-key-here...

# OPTIONAL: Hugging Face API Key
# Get yours from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=...your-token-here...

# OPTIONAL: SerpAPI Key for web search
# Get yours from: https://serpapi.com/
SERPAPI_API_KEY=...your-api-key-here...

# DEBUG Mode (true/false)
DEBUG=False

# Project name
PROJECT_NAME=Capstone_Sales_Analysis

