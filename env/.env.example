# Environment configuration file
# Copy this file to .env and fill in your actual API keys
# IMPORTANT: Never commit .env to version control!

# ============================================
# REQUIRED SECRETS
# ============================================

# OpenAI API Key (required)
# Get yours from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# OPTIONAL SECRETS
# ============================================

# Anthropic Claude API Key (optional)
# Get yours from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Hugging Face API Key (optional)
# Get yours from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# SerpAPI Key for web search (optional)
# Get yours from: https://serpapi.com/
SERPAPI_API_KEY=your_serpapi_api_key_here

# ============================================
# PROJECT SETTINGS
# ============================================

# Debug mode (true/false)
DEBUG=False

# Project name
PROJECT_NAME=Capstone_Sales_Analysis

# LLM Settings
LLM_MODEL=gpt-4
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# ============================================
# DATABASE SETTINGS
# ============================================

# Vector database type (FAISS)
VECTOR_DB_PATH=vector_db

# ============================================
# APPLICATION SETTINGS
# ============================================

# Streamlit theme (light/dark)
STREAMLIT_THEME=light

# Maximum file upload size (in MB)
MAX_UPLOAD_SIZE=100

# Number of search results to return
NUM_SEARCH_RESULTS=5
